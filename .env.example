# Odoo Configuration
ODOO_BASE_URL=https://your-odoo-instance.odoo.com
ODOO_DB=your-database-name
ODOO_LOGIN=your-email@example.com
ODOO_API_KEY=your-api-key-here

# Session Security
SESSION_SECRET=your-secret-session-key-here
# Webhook Security (voor Odoo eigen DB synchronisatie)
WEBHOOK_SECRET=your-webhook-secret-here

# Database
DATABASE_URL=postgresql://user:password@host:port/database

# SMTP Mail Configuration (DEPRECATED - gebruik Gmail API)
SMTP_USER=
SMTP_PASSWORD=

# Gmail API Configuration (OAuth2)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
